<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/blanco"
    tools:context=".InterfazClase">

    <LinearLayout
        android:id="@+id/cabeceraClase"
        android:orientation="vertical"
        android:paddingTop="50dp"
        android:paddingBottom="15dp"
        android:paddingHorizontal="20dp"
        android:background="@drawable/cabecera_clase"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/btnRegresar"
                android:layout_width="30dp"
                android:layout_height="30dp"
                android:text="&lt;"
                android:textSize="20sp"
                android:textColor="@color/grisPalidoOscuro"
                android:fontFamily="@font/montserrat_extra_bold"
                android:gravity="center"
                android:background="@drawable/fondo_boton_regresar"
                android:padding="0dp"
                android:minWidth="0dp"
                android:minHeight="0dp"/>

            <TextView
                android:text="Regresar"
                android:textSize="15sp"
                android:textColor="@color/blanco"
                android:layout_marginStart="7dp"
                android:fontFamily="@font/montserrat_semi_bold"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>
        </LinearLayout>

        <TextView
            android:id="@+id/nombreClaseInterfaz"
            android:fontFamily="@font/montserrat_semi_bold"
            android:text="Conmutación y Enrutamiento de Redes de Datos"
            android:textColor="@color/blanco"
            android:textAlignment="inherit"
            android:textSize="20sp"
            android:layout_marginVertical="5dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"/>

        <LinearLayout
            android:orientation="horizontal"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <LinearLayout
                android:id="@+id/infoGrupoClase"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/fondo_redondeado"
                android:paddingVertical="3dp"
                android:paddingHorizontal="10dp"
                android:gravity="center_vertical"
                android:layout_marginEnd="5dp">

                <ImageView
                    android:id="@+id/infoIconoGrupo"
                    android:src="@drawable/icono_grupo"
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:layout_marginEnd="3dp"/>

                <TextView
                    android:id="@+id/grupoClaseIntefaz"
                    android:text="185601"
                    android:fontFamily="@font/montserrat_extra_bold"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>

            </LinearLayout>


            <LinearLayout
                android:id="@+id/infoAulaClase"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/fondo_redondeado"
                android:paddingVertical="3dp"
                android:paddingHorizontal="10dp"
                android:gravity="center_vertical"
                android:layout_marginEnd="5dp">

                <ImageView
                    android:id="@+id/infoIconoAula"
                    android:src="@drawable/icono_actividades"
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:layout_marginEnd="3dp"/>

                <TextView
                    android:id="@+id/aulaClaseIntefaz"
                    android:text="T-11"
                    android:fontFamily="@font/montserrat_extra_bold_italic"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>

            </LinearLayout>

            <Space
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"/>

            <ImageButton
                android:src="@drawable/icono_configuracion"
                android:background="@android:color/transparent"
                android:layout_width="25dp"
                android:layout_height="25dp"
                android:padding="1dp"
                android:scaleType="centerInside"
                app:tint="@color/blanco" />
        </LinearLayout>
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical"
        android:padding="15dp">

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvCriteriosClase"
            android:orientation="horizontal"
            android:layout_width="match_parent"
            android:layout_height="50dp"/>

        <TextView
            android:id="@+id/nombreCriterioClase"
            android:text="Ejemplo: Asistencia"
            android:fontFamily="@font/montserrat_semi_bold"
            android:textSize="20sp"
            android:layout_marginVertical="10dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:layout_marginBottom="15dp">

                <androidx.viewpager2.widget.ViewPager2
                android:id="@+id/viewPagerCriterios"
                android:layout_width="match_parent"
                android:layout_height="match_parent"/>
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:weightSum="2"
            android:orientation="horizontal"
            android:layout_marginBottom="15dp">

            <LinearLayout
                android:id="@+id/btnCalendarioCumplimiento"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginEnd="10dp"
                android:background="@drawable/fondo_redondeado"
                android:backgroundTint="@color/grisPalidoClaro"
                android:focusable="true"
                android:clickable="true"
                android:padding="5dp"
                android:orientation="vertical"
                android:gravity="center">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center">

                    <ImageView
                        android:src="@drawable/icono_cumplimiento"
                        android:layout_width="25dp"
                        android:layout_height="25dp"
                        android:layout_marginEnd="2dp"
                        />

                    <TextView
                        android:id="@+id/porcentajeCumplimientoReciente"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="89%"
                        android:textColor="@color/grisPalidoOscuro"
                        android:fontFamily="@font/montserrat_extra_bold_italic"
                        android:textSize="20sp"/>

                </LinearLayout>

                <TextView
                    android:text="CUMPLIMIENTO \nÚLTIMA SESIÓN"
                    android:layout_width="wrap_content"
                    android:padding="0dp"
                    android:layout_marginHorizontal="10dp"
                    android:layout_height="wrap_content"
                    android:textAlignment="center"
                    android:fontFamily="@font/montserrat_extra_bold"
                    android:textSize="10sp"/>

            </LinearLayout>


            <LinearLayout
                android:id="@+id/btnBajoCumplimiento"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="6dp"
                android:background="@drawable/fondo_redondeado"
                android:backgroundTint="@color/grisPalidoClaro"
                android:focusable="true"
                android:clickable="true"
                android:padding="5dp"
                android:orientation="vertical"
                android:gravity="center">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center">

                    <ImageView
                        android:src="@drawable/icono_alumno"
                        android:layout_width="25dp"
                        android:layout_height="25dp"/>

                    <TextView
                        android:id="@+id/numeroAlumnosRiesgo"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="@color/grisPalidoOscuro"
                        android:text="14"
                        android:fontFamily="@font/montserrat_extra_bold_italic"
                        android:textSize="20sp"/>

                </LinearLayout>

                <TextView
                    android:text="ALUMNOS CON BAJO CUMPLIMIENTO"
                    android:fontFamily="@font/montserrat_extra_bold"
                    android:textSize="10sp"
                    android:textAlignment="center"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"/>

            </LinearLayout>
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:background="@drawable/fondo_redondeado"
            android:backgroundTint="@color/azulArse"
            android:padding="10dp"
            android:gravity="center"
            android:visibility="invisible"
            android:layout_marginBottom="5dp">

            <ImageView
                android:src="@drawable/icono_registrar"
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:layout_marginEnd="5dp"/>

            <TextView
                android:text="EXPORTAR"
                android:textSize="15sp"
                android:textColor="@color/blanco"
                android:fontFamily="@font/montserrat_extra_bold_italic"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>

        </LinearLayout>

    </LinearLayout>

</LinearLayout>