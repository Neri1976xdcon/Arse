<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/fondo_degradado"
    tools:context=".Calendario">

    <!-- HEADER -->
    <LinearLayout
        android:id="@+id/header"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingHorizontal="30dp"
        android:paddingTop="10dp"
        android:paddingBottom="10dp"
        android:gravity="center_vertical"
        app:layout_constraintTop_toTopOf="parent">

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btnRegresar"
            android:layout_width="35dp"
            android:layout_height="35dp"
            android:text="&lt;"
            android:textSize="23sp"
            android:textColor="@color/grisPalidoOscuro"
            android:fontFamily="@font/montserrat_extra_bold"
            android:gravity="center"
            android:background="@drawable/fondo_boton_regresar"
            android:padding="0dp"
            android:minWidth="0dp"
            android:minHeight="0dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="7dp"
            android:text="Regresar"
            android:textSize="15sp"
            android:fontFamily="@font/montserrat_semi_bold"/>
    </LinearLayout>

    <!-- CONTENIDO -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:orientation="vertical"
        android:paddingHorizontal="30dp"
        android:paddingBottom="20dp"
        app:layout_constraintTop_toBottomOf="@id/header"
        app:layout_constraintBottom_toBottomOf="parent">

        <TextView
            android:text="Resumen de cumplimiento"
            android:textSize="23sp"
            android:fontFamily="@font/montserrat_extra_bold"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center">

            <TextView
                android:id="@+id/porcentajeCumplimientoGeneral"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text=""
                android:paddingVertical="5dp"
                android:paddingHorizontal="10dp"
                android:textColor="@color/blanco"
                android:textSize="15sp"
                android:fontFamily="@font/montserrat_extra_bold"
                android:background="@drawable/fondo_redondeado"
                android:layout_marginEnd="5dp"/>

            <TextView
                android:id="@+id/textoCumplimientoGeneral"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="CUMPLIMIENTO GENERAL"
                android:textSize="15sp"
                android:fontFamily="@font/montserrat_extra_bold"/>

        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginVertical="10dp">

            <TextView
                android:text="CALENDARIO"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:fontFamily="@font/montserrat_extra_bold_italic"
                android:textSize="17sp"
                android:textColor="@color/azulOscuro"/>

            <Spinner
                android:id="@+id/seleccionMes"
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:paddingHorizontal="5dp"
                android:backgroundTint="@color/grisPalidoClaro"
                android:background="@drawable/fondo_redondeado"/>

        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="LUNES"
                android:textSize="8sp"
                android:textAlignment="center"
                android:fontFamily="@font/montserrat_semi_bold"/>

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="MARTES"
                android:textSize="8sp"
                android:textAlignment="center"
                android:fontFamily="@font/montserrat_semi_bold"/>

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="MIÉRCOLES"
                android:textSize="8sp"
                android:textAlignment="center"
                android:fontFamily="@font/montserrat_semi_bold"/>

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="JUEVES"
                android:textSize="8sp"
                android:textAlignment="center"
                android:fontFamily="@font/montserrat_semi_bold"/>

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="VIERNES"
                android:textSize="8sp"
                android:textAlignment="center"
                android:fontFamily="@font/montserrat_semi_bold"/>

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="SÁBADO"
                android:textSize="8sp"
                android:textAlignment="center"
                android:fontFamily="@font/montserrat_semi_bold"/>

        </LinearLayout>

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvSemanasCalendario"
            android:layout_width="match_parent"
            android:paddingVertical="5dp"
            android:layout_height="175dp"/>

        <TextView
            android:text="DETALLES"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:fontFamily="@font/montserrat_extra_bold_italic"
            android:textSize="17sp"
            android:textColor="@color/azulOscuro"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingVertical="5dp">

            <TextView
                android:id="@+id/textoIndicadorPorcentaje"
                android:text="ASISTENCIA"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:fontFamily="@font/montserrat_semi_bold"
                android:textSize="12sp"/>

            <TextView
                android:text="INASISTENCIA"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/montserrat_semi_bold"
                android:textSize="12sp"
                android:textColor="@color/grisPalidoOscuro"/>

        </LinearLayout>

        <FrameLayout
            android:id="@+id/contenedorPorcentaje"
            android:layout_width="match_parent"
            android:layout_height="25dp"
            android:layout_gravity="center_vertical"
            android:background="@drawable/fondo_redondeado"
            android:backgroundTint="@color/grisPalidoClaro">

            <TextView
                android:id="@+id/porcentaje"
                android:text=""
                android:textColor="@color/blanco"
                android:fontFamily="@font/montserrat_extra_bold"
                android:textAlignment="center"
                android:paddingHorizontal="5dp"
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:background="@drawable/fondo_redondeado"/>
        </FrameLayout>

        <TextView
            android:text="ALUMNOS"
            android:layout_marginTop="15dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:fontFamily="@font/montserrat_extra_bold_italic"
            android:textSize="17sp"
            android:textColor="@color/azulOscuro"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <LinearLayout
                android:id="@+id/contenedorBuscador"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginEnd="10dp"
                android:gravity="center_vertical"
                android:paddingHorizontal="10dp"
                android:paddingVertical="7dp"
                android:background="@drawable/fondo_redondeado"
                android:backgroundTint="@color/grisPalidoClaro">

                <ImageView
                    android:src="@drawable/icono_buscar"
                    android:layout_width="15dp"
                    android:layout_height="15dp"
                    android:layout_marginHorizontal="5dp"/>

                <EditText
                    android:id="@+id/buscadorAlumnos"
                    android:hint="BUSCAR ALUMNOS"
                    android:maxLines="1"
                    android:inputType="text"
                    android:scrollHorizontally="true"
                    android:background="@null"
                    android:fontFamily="@font/montserrat_semi_bold"
                    android:textSize="12sp"
                    android:textColorHint="@color/grisPalidoOscuro"
                    android:textColor="@color/grisPalidoOscuro"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"/>
            </LinearLayout>

            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/conAsistencia"
                android:layout_width="35dp"
                android:layout_height="35dp"
                android:text="✔"
                android:textSize="20sp"
                android:background="@drawable/fondo_mas"
                android:layout_marginEnd="10dp"/>

            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/sinAsistencia"
                android:layout_width="35dp"
                android:layout_height="35dp"
                android:text="✘"
                android:textSize="20sp"
                android:background="@drawable/fondo_menos"/>

        </LinearLayout>

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvAlumnos"
            android:layout_width="match_parent"
            android:layout_marginTop="10dp"
            android:layout_height="0dp"
            android:layout_weight="1"/>

        <TextView
            android:id="@+id/mensajeVacio"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:gravity="center"
            android:text="SELECCIONE UN DÍA PARA VER LA LISTA DE ALUMNOS O  NO HUBO TOMA DE ASISTENCIA ESTE DÍA"
            android:fontFamily="@font/montserrat_semi_bold"
            android:textAlignment="center"
            android:visibility="gone"/>

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>