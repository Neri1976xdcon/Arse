<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:paddingBottom="15dp">

    <LinearLayout
        android:id="@+id/contenedorDia"
        android:layout_width="0dp"
        android:layout_height="50dp"
        android:background="@drawable/fondo_redondeado"
        android:gravity="center_vertical"
        android:paddingHorizontal="20dp"
        android:orientation="horizontal"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:id="@+id/nombreDia"
            android:text="Dia"
            android:textColor="@color/grisPalidoOscuro"
            android:fontFamily="@font/montserrat_extra_bold"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textSize="15sp"/>

        <ImageView
            android:id="@+id/flecha"
            android:layout_width="15dp"
            android:layout_height="15dp"
            android:src="@drawable/icono_flecha_abajo"/>

    </LinearLayout>

    <LinearLayout
        android:id="@+id/layoutHorario"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:layout_marginTop="20dp"
        android:paddingBottom="10dp"
        app:layout_constraintTop_toBottomOf="@id/contenedorDia"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        >

        <LinearLayout
            android:orientation="horizontal"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_horizontal">

            <TextView
                android:text="DE"
                android:textSize="15sp"
                android:layout_marginEnd="10dp"
                android:fontFamily="@font/montserrat_extra_bold"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>

            <EditText
                android:id="@+id/etHoraInicio"
                android:layout_width="50dp"
                android:layout_height="wrap_content"
                android:hint="00"
                android:textSize="15sp"
                android:paddingVertical="10dp"
                android:paddingHorizontal="5dp"
                android:textAlignment="center"
                android:fontFamily="@font/montserrat_extra_bold"
                android:textColor="@drawable/texto_edit_text"
                android:background="@drawable/fondo_escribir"/>

            <TextView
                android:text=":"
                android:textSize="25sp"
                android:fontFamily="@font/montserrat_extra_bold"
                android:layout_marginHorizontal="5dp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>

            <EditText
                android:id="@+id/etMinutosInicio"
                android:layout_width="50dp"
                android:layout_height="wrap_content"
                android:hint="00"
                android:textSize="15sp"
                android:paddingVertical="10dp"
                android:paddingHorizontal="5dp"
                android:textAlignment="center"
                android:fontFamily="@font/montserrat_extra_bold"
                android:textColor="@drawable/texto_edit_text"
                android:background="@drawable/fondo_escribir"/>

            <TextView
                android:text="A"
                android:textSize="15sp"
                android:layout_marginHorizontal="10dp"
                android:fontFamily="@font/montserrat_extra_bold"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>


            <EditText
                android:id="@+id/etHoraFin"
                android:layout_width="50dp"
                android:layout_height="wrap_content"
                android:hint="00"
                android:textSize="15sp"
                android:paddingVertical="10dp"
                android:paddingHorizontal="5dp"
                android:textAlignment="center"
                android:fontFamily="@font/montserrat_extra_bold"
                android:textColor="@drawable/texto_edit_text"
                android:background="@drawable/fondo_escribir"/>

            <TextView
                android:text=":"
                android:textSize="25sp"
                android:fontFamily="@font/montserrat_extra_bold"
                android:layout_marginHorizontal="5dp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>

            <EditText
                android:id="@+id/etMinutosFin"
                android:layout_width="50dp"
                android:layout_height="wrap_content"
                android:hint="00"
                android:textSize="15sp"
                android:paddingVertical="10dp"
                android:paddingHorizontal="5dp"
                android:textAlignment="center"
                android:fontFamily="@font/montserrat_extra_bold"
                android:textColor="@drawable/texto_edit_text"
                android:background="@drawable/fondo_escribir"/>

        </LinearLayout>

        <TextView
            android:id="@+id/mensajeHorario"
            android:text="HORARIO INCOMPLETO"
            android:visibility="gone"
            android:textColor="@color/rojoError"
            android:paddingVertical="10dp"
            android:fontFamily="@font/montserrat_extra_bold_italic"
            android:textAlignment="textEnd"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"/>



    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>