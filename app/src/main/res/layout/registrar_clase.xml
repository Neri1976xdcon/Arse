<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/fondo_degradado">

    <!-- HEADER FIJO -->
    <LinearLayout
        android:id="@+id/header"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingHorizontal="30dp"
        android:paddingTop="40dp"
        android:paddingBottom="10dp"
        android:gravity="center_vertical"
        app:layout_constraintTop_toTopOf="parent">

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btnRegresar"
            android:layout_width="35dp"
            android:layout_height="35dp"
            android:text="&lt;"
            android:textSize="23sp"
            android:textColor="@color/grisPalidoOscuro"
            android:fontFamily="@font/montserrat_extra_bold"
            android:gravity="center"
            android:background="@drawable/fondo_boton_regresar"
            android:padding="0dp"
            android:minWidth="0dp"
            android:minHeight="0dp"/>

        <TextView
            android:text="Regresar"
            android:textSize="15sp"
            android:layout_marginStart="7dp"
            android:fontFamily="@font/montserrat_semi_bold"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>
    </LinearLayout>

    <!-- CONTENIDO CON SCROLL -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:fillViewport="true"
        app:layout_constraintTop_toBottomOf="@id/header"
        app:layout_constraintBottom_toBottomOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="30dp"
            android:paddingBottom="50dp">

            <TextView
                android:text="@string/registrar_clase"
                android:textSize="25sp"
                android:fontFamily="@font/montserrat_extra_bold"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"/>

            <TextView
                android:text="Asignatura:"
                android:fontFamily="@font/montserrat_semi_bold"
                android:textSize="18sp"
                android:layout_marginVertical="5dp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"/>

            <TextView
                android:id="@+id/mensajeAsignaturaClase"
                android:text="👇 Obligatorio"
                android:visibility="gone"
                android:textColor="@color/rojoError"
                android:fontFamily="@font/montserrat_medium"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"/>

            <EditText
                android:id="@+id/asignatura"
                android:hint="Ingrese nombre"
                android:textColor="@drawable/texto_edit_text"
                android:textSize="15sp"
                android:fontFamily="@font/montserrat_extra_bold"
                android:background="@drawable/fondo_escribir"
                android:paddingVertical="10dp"
                android:paddingHorizontal="15dp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"/>

            <TextView
                android:text="Grupo:"
                android:fontFamily="@font/montserrat_semi_bold"
                android:textSize="18sp"
                android:layout_marginTop="15dp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"/>

            <TextView
                android:id="@+id/mensajeGrupoClase"
                android:text="👇 Seleccione un grupo"
                android:visibility="gone"
                android:textColor="@color/rojoError"
                android:fontFamily="@font/montserrat_medium"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"/>

            <LinearLayout
                android:id="@+id/seleccionarGrupo"
                android:orientation="horizontal"
                android:gravity="center"
                android:clickable="true"
                android:focusable="true"
                android:paddingVertical="5dp"
                android:layout_marginVertical="5dp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/fondo_grupo">

                <ImageView
                    android:src="@drawable/icono_grupo"
                    android:layout_width="35dp"
                    android:layout_height="35dp"
                    android:layout_marginEnd="5dp"/>

                <TextView
                    android:id="@+id/textoSeleccionGrupo"
                    android:text="SELECCIONAR GRUPO"
                    android:fontFamily="@font/montserrat_extra_bold"
                    android:gravity="center"
                    android:textColor="@color/grisPalidoOscuro"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>
            </LinearLayout>

            <LinearLayout
                android:orientation="horizontal"
                android:paddingVertical="2dp"
                android:gravity="end"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <TextView
                    android:text="¿Aún no tienes un grupo?"
                    android:textSize="12sp"
                    android:layout_marginEnd="2dp"
                    android:fontFamily="@font/montserrat_medium"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>

                <Button
                    android:id="@+id/crearGrupoInterfaz"
                    android:text="Crea uno"
                    android:textSize="12sp"
                    android:fontFamily="@font/montserrat_extra_bold"
                    android:textColor="@color/negro"
                    android:background="@android:color/transparent"
                    android:minHeight="0dp"
                    android:minWidth="0dp"
                    android:padding="0dp"
                    android:insetTop="0dp"
                    android:insetBottom="0dp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>
            </LinearLayout>

            <TextView
                android:text="Horario:"
                android:fontFamily="@font/montserrat_semi_bold"
                android:textSize="18sp"
                android:layout_marginBottom="5dp"
                android:layout_marginTop="15dp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"/>

            <TextView
                android:id="@+id/mensajeHorarioClase"
                android:text="👇 Registre al menos una sesión de clase"
                android:textColor="@color/rojoError"
                android:visibility="gone"
                android:fontFamily="@font/montserrat_medium"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"/>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvHorario"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:nestedScrollingEnabled="false"
                android:paddingBottom="10dp"/>

            <TextView
                android:text="Criterios:"
                android:fontFamily="@font/montserrat_semi_bold"
                android:textSize="18sp"
                android:layout_marginVertical="5dp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"/>

            <TextView
                android:id="@+id/mensajeCriteriosClase"
                android:text="👇 Seleccione al menos un criterio"
                android:textColor="@color/rojoError"
                android:visibility="gone"
                android:fontFamily="@font/montserrat_medium"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"/>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvCriterios"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:nestedScrollingEnabled="false"/>

            <TextView
                android:text="Tema:"
                android:fontFamily="@font/montserrat_semi_bold"
                android:textSize="18sp"
                android:layout_marginTop="15dp"
                android:layout_marginBottom="5dp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"/>

            <TextView
                android:text="👀 Opcional"
                android:fontFamily="@font/montserrat_medium"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"/>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvTemas"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"/>

            <LinearLayout
                android:id="@+id/registrarClase"
                android:background="@drawable/fondo_redondeado"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center"
                android:clickable="true"
                android:focusable="true"
                android:padding="10dp"
                android:layout_marginVertical="20dp">

                <ImageView
                    android:src="@drawable/icono_registrar"
                    android:layout_width="15dp"
                    android:layout_height="15dp"
                    android:layout_marginEnd="5dp"/>

                <TextView
                    android:text="REGISTRAR"
                    android:fontFamily="@font/montserrat_extra_bold_italic"
                    android:textSize="15sp"
                    android:textColor="@color/blanco"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>

            </LinearLayout>

        </LinearLayout>

    </androidx.core.widget.NestedScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>


