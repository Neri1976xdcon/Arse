<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="15dp"
    android:background="@drawable/fondo_dialog"
    android:orientation="vertical">

    <TextView
        android:text="AGREGAR ALUMNOS"
        android:fontFamily="@font/montserrat_extra_bold_italic"
        android:textSize="15sp"
        android:textAlignment="center"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"/>

    <LinearLayout
        android:id="@+id/contenedorBuscador"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:paddingHorizontal="10dp"
        android:paddingVertical="10dp"
        android:layout_marginVertical="5dp"
        android:background="@drawable/fondo_redondeado"
        android:backgroundTint="@color/grisPalidoClaro">

        <ImageView
            android:src="@drawable/icono_buscar"
            android:layout_width="15dp"
            android:layout_height="15dp"
            android:layout_marginHorizontal="5dp"/>

        <EditText
            android:id="@+id/buscadorAlumnos"
            android:hint="Buscar alumnos"
            android:maxLines="1"
            android:inputType="text"
            android:scrollHorizontally="true"
            android:background="@null"
            android:fontFamily="@font/montserrat_semi_bold"
            android:textSize="12sp"
            android:textColorHint="@color/grisPalidoOscuro"
            android:textColor="@color/grisPalidoOscuro"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"/>
    </LinearLayout>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvAgregarAlumnos"
        android:layout_width="match_parent"
        android:layout_height="150dp"
        android:paddingVertical="5dp"/>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/cancelarAgregarAlumnos"
            android:text="@string/cancelar"
            android:textSize="15sp"
            android:background="@color/blanco"
            android:fontFamily="@font/montserrat_extra_bold"
            android:layout_width="wrap_content"
            android:elevation="0dp"
            android:translationZ="0dp"
            android:textColor="@drawable/texto_seleccion_cancelacion"
            android:stateListAnimator="@null"
            android:layout_height="wrap_content"/>

        <Space
            android:layout_weight="1"
            android:layout_width="0dp"
            android:layout_height="wrap_content"/>

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/agregarAlumnos"
            android:text="@string/confirmar"
            android:textSize="15sp"
            android:elevation="0dp"
            android:translationZ="0dp"
            android:stateListAnimator="@null"
            android:background="@color/blanco"
            android:textColor="@drawable/texto_seleccion_registro"
            android:fontFamily="@font/montserrat_extra_bold"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>

    </LinearLayout>
</LinearLayout>