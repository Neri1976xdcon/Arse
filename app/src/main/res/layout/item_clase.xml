<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="90dp"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:padding="5dp"
    android:gravity="center"
    android:clickable="true"
    android:focusable="true"
    android:background="@drawable/fondo_redondeado"
    android:backgroundTint="@color/blanco"
    android:orientation="horizontal"
    android:layout_marginBottom="10dp">

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_weight="1"
        android:layout_height="wrap_content"
        android:paddingHorizontal="8dp"
        android:orientation="vertical">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="5dp">

            <TextView
                android:id="@+id/grupoClase"
                android:text="185601"
                android:fontFamily="@font/montserrat_extra_bold_italic"
                android:textColor="@color/blanco"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/fondo_redondeado"
                android:textSize="10sp"
                android:paddingVertical="3dp"
                android:paddingHorizontal="10dp"
                android:layout_marginEnd="5dp"/>

            <TextView
                android:id="@+id/aulaClase"
                android:text="TLC-5"
                android:fontFamily="@font/montserrat_extra_bold_italic"
                android:textColor="@color/azulArse"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/fondo_redondeado"
                android:backgroundTint="@color/grisPalidoClaro"
                android:paddingVertical="3dp"
                android:paddingHorizontal="10dp"
                android:textSize="10sp"
                android:layout_marginEnd="5dp"/>
        </LinearLayout>

        <TextView
            android:id="@+id/asignaturaClase"
            android:text="Asignatura"
            android:fontFamily="@font/montserrat_semi_bold"
            android:textSize="13sp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>

    </LinearLayout>

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/fondoImagenClase"
        android:layout_width="80dp"
        android:layout_height="80dp"
        android:padding="10dp"
        android:background="@drawable/fondo_redondeado">

        <ImageView
            android:id="@+id/iconoClase"
            android:src="@drawable/icono_actividades"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            app:tint="@color/blanco" />

    </androidx.constraintlayout.widget.ConstraintLayout>

</LinearLayout>