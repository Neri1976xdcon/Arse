<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/fondo_degradado"
    tools:context=".BajoCumplimiento">

    <!-- HEADER -->
    <LinearLayout
        android:id="@+id/header"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingHorizontal="30dp"
        android:paddingTop="40dp"
        android:paddingBottom="10dp"
        android:gravity="center_vertical"
        app:layout_constraintTop_toTopOf="parent">

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btnRegresar"
            android:layout_width="35dp"
            android:layout_height="35dp"
            android:text="&lt;"
            android:textSize="23sp"
            android:textColor="@color/grisPalidoOscuro"
            android:fontFamily="@font/montserrat_extra_bold"
            android:gravity="center"
            android:background="@drawable/fondo_boton_regresar"
            android:padding="0dp"
            android:minWidth="0dp"
            android:minHeight="0dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="7dp"
            android:text="Regresar"
            android:textSize="15sp"
            android:fontFamily="@font/montserrat_semi_bold"/>
    </LinearLayout>

    <!-- CONTENIDO -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:orientation="vertical"
        android:paddingHorizontal="30dp"
        android:paddingBottom="20dp"
        app:layout_constraintTop_toBottomOf="@id/header"
        app:layout_constraintBottom_toBottomOf="parent">

        <TextView
            android:text="Bajo cumplimiento"
            android:textSize="25sp"
            android:fontFamily="@font/montserrat_extra_bold"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginVertical="5dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginVertical="5dp">

            <TextView
                android:id="@+id/numeroAlumnosRiesgo"
                android:text="5"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/montserrat_extra_bold_italic"
                android:textSize="17sp"
                android:textColor="@color/blanco"
                android:background="@drawable/fondo_redondeado"
                android:backgroundTint="@color/naranjaOscuro"
                android:paddingHorizontal="10dp"
                android:layout_marginEnd="10dp"/>

            <TextView
                android:text="ALUMNOS EN RIESGO"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/montserrat_extra_bold_italic"
                android:textSize="17sp"
                android:textColor="@color/naranjaOscuro"/>
        </LinearLayout>

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvAlumnosRiesgo"
            android:layout_width="match_parent"
            android:layout_marginVertical="5dp"
            android:layout_height="0dp"
            android:layout_weight="1"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginVertical="5dp">

            <TextView
                android:id="@+id/numeroAlumnosCriticos"
                android:text="5"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/montserrat_extra_bold_italic"
                android:textSize="17sp"
                android:textColor="@color/blanco"
                android:background="@drawable/fondo_redondeado"
                android:backgroundTint="@color/rojoError"
                android:paddingHorizontal="10dp"
                android:layout_marginEnd="10dp"/>

            <TextView
                android:text="CASOS CRÍTICOS"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/montserrat_extra_bold_italic"
                android:textSize="17sp"
                android:textColor="@color/rojoError"/>
        </LinearLayout>

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvAlumnosCritico"
            android:layout_width="match_parent"
            android:layout_marginVertical="10dp"
            android:layout_height="0dp"
            android:layout_weight="1"/>

        <TextView
            android:id="@+id/mensajeVacio"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:gravity="center"
            android:text="SELECCIONE UN DÍA PARA VER LA LISTA DE ALUMNOS O  NO HUBO TOMA DE ASISTENCIA ESTE DÍA"
            android:fontFamily="@font/montserrat_semi_bold"
            android:textAlignment="center"
            android:visibility="gone"/>

        <TextView
            android:text="Bajo cumplimiento"
            android:textSize="25sp"
            android:fontFamily="@font/montserrat_extra_bold"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"/>


        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginVertical="10dp">

            <TextView
                android:text="CALENDARIO"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:fontFamily="@font/montserrat_extra_bold_italic"
                android:textSize="17sp"
                android:textColor="@color/azulOscuro"/>

            <Spinner
                android:id="@+id/seleccionMes"
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:paddingHorizontal="5dp"
                android:backgroundTint="@color/grisPalidoClaro"
                android:background="@drawable/fondo_redondeado"/>

        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="LUNES"
                android:textSize="8sp"
                android:textAlignment="center"
                android:fontFamily="@font/montserrat_semi_bold"/>

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="MARTES"
                android:textSize="8sp"
                android:textAlignment="center"
                android:fontFamily="@font/montserrat_semi_bold"/>

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="MIÉRCOLES"
                android:textSize="8sp"
                android:textAlignment="center"
                android:fontFamily="@font/montserrat_semi_bold"/>

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="JUEVES"
                android:textSize="8sp"
                android:textAlignment="center"
                android:fontFamily="@font/montserrat_semi_bold"/>

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="VIERNES"
                android:textSize="8sp"
                android:textAlignment="center"
                android:fontFamily="@font/montserrat_semi_bold"/>

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="SÁBADO"
                android:textSize="8sp"
                android:textAlignment="center"
                android:fontFamily="@font/montserrat_semi_bold"/>

        </LinearLayout>

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvSemanasAlumnoCalendario"
            android:layout_width="match_parent"
            android:layout_height="200dp"
            android:paddingVertical="5dp"/>


    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>