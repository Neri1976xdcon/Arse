<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="15dp"
    android:background="@drawable/fondo_dialog">

    <TextView
        android:id="@+id/tituloRemover"
        android:text="¿QUITAR/ELIMINAR ESTE ALUMNO DEL_GRUPO/DEFINITIVATE?"
        android:fontFamily="@font/montserrat_extra_bold_italic"
        android:textSize="15sp"
        android:textAlignment="center"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"/>

    <TextView
        android:id="@+id/nombreAlumno"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Melo Sámano Carlos Daniel"
        android:textAlignment="center"
        android:textSize="15dp"
        android:paddingVertical="15dp"
        android:textColor="@color/rojoError"
        android:fontFamily="@font/montserrat_extra_bold"/>

    <TextView
        android:text="SE ELIMINARÁN LOS DATOS RELACIONADOS A ESTE ALUMNO"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:fontFamily="@font/montserrat_medium"
        android:textAlignment="center"/>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/cancelarRemover"
            android:text="@string/cancelar"
            android:textSize="15sp"
            android:background="@color/blanco"
            android:fontFamily="@font/montserrat_extra_bold"
            android:layout_width="wrap_content"
            android:elevation="0dp"
            android:translationZ="0dp"
            android:textColor="@drawable/texto_seleccion_cancelacion"
            android:stateListAnimator="@null"
            android:layout_height="wrap_content"/>

        <Space
            android:layout_weight="1"
            android:layout_width="0dp"
            android:layout_height="wrap_content"/>

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/confirmarRemover"
            android:text="@string/confirmar"
            android:textSize="15sp"
            android:elevation="0dp"
            android:translationZ="0dp"
            android:stateListAnimator="@null"
            android:background="@color/blanco"
            android:textColor="@drawable/texto_seleccion_registro"
            android:fontFamily="@font/montserrat_extra_bold"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>

    </LinearLayout>

</LinearLayout>