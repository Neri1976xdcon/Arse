<?xml version="1.0" encoding="utf-8"?>
<androidx.drawerlayout.widget.DrawerLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/drawer_layout"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <androidx.coordinatorlayout.widget.CoordinatorLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <!-- PRINCIPAL  -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:paddingHorizontal="40dp"
            android:background="@drawable/fondo_degradado"
            android:gravity="center"
            android:paddingVertical="16dp">

            <ScrollView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:fillViewport="true"
                android:overScrollMode="never"
                android:scrollbars="none">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:paddingBottom="100dp">
                    <Space
                        android:layout_width="match_parent"
                        android:layout_height="150dp"/>

                    <LinearLayout
                        android:orientation="horizontal"
                        android:gravity="center"
                        android:layout_marginTop="150dp"
                        android:layout_marginVertical="15dp"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content">

                        <FrameLayout
                            android:layout_width="80dp"
                            android:layout_height="80dp"
                            android:layout_gravity="center"
                            android:layout_marginEnd="5dp">

                            <ImageView
                                android:src="@drawable/arse_icono"
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"/>

                            <ImageView
                                android:id="@+id/arseIconoPaloma"
                                android:visibility="gone"
                                android:src="@drawable/arse_aprovacion"
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"/>

                            <ImageView
                                android:id="@+id/arseIconoTache"
                                android:visibility="gone"
                                android:src="@drawable/arse_tache"
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"/>
                        </FrameLayout>

                        <ImageView
                            android:src="@drawable/arse_texto"
                            android:layout_width="140dp"
                            android:layout_height="50dp"/>
                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/btnRegistrar"
                        android:orientation="horizontal"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:clickable="true"
                        android:focusable="true"
                        android:layout_marginVertical="15dp"
                        android:paddingVertical="10dp"
                        android:layout_marginHorizontal="35dp"
                        android:gravity="center"
                        android:background="@drawable/fondo_redondeado">

                        <ImageView
                            android:src="@drawable/icono_registrar"
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:padding="1dp"
                            android:layout_marginRight="5dp"/>

                        <TextView
                            android:text="@string/registrar_btn"
                            android:fontFamily="@font/montserrat_extra_bold"
                            android:textSize="15sp"
                            android:textColor="@color/blanco"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"/>
                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/asistenciaActiva"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:padding="10dp"
                        android:clickable="true"
                        android:focusable="true"
                        android:gravity="center"
                        android:layout_marginBottom="15dp"
                        android:background="@drawable/fondo_redondeado"
                        android:backgroundTint="@color/grisPalidoClaro">

                        <ImageView
                            android:src="@drawable/icono_asistencia"
                            android:layout_width="30dp"
                            android:layout_height="30dp"
                            android:layout_marginEnd="10dp"/>

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical">

                            <TextView
                                android:text="REGISTRO DE ASISTENCIA ACTIVO"
                                android:fontFamily="@font/montserrat_medium"
                                android:textSize="10sp"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"/>

                            <TextView
                                android:id="@+id/asistenciaActivaAsignatura"
                                android:text="CONMUTACIÒN Y ENRUTAMIENTO DE REDES DE DATOS"
                                android:fontFamily="@font/montserrat_extra_bold_italic"
                                android:textSize="12sp"
                                android:textColor="@color/azulArse"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"/>

                        </LinearLayout>
                    </LinearLayout>

                    <TextView
                        android:text="Pendientes"
                        android:fontFamily="@font/montserrat_extra_bold_italic"
                        android:textSize="18sp"
                        android:visibility="gone"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"/>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="5dp"
                        android:visibility="gone"
                        android:background="@color/verdeDrawer"/>

                    <LinearLayout
                        android:id="@+id/mensajeSinPendientes"
                        android:layout_width="match_parent"
                        android:layout_height="150dp"
                        android:orientation="horizontal"
                        android:gravity="center"
                        android:visibility="gone"
                        android:paddingVertical="15dp">
                        <ImageView
                            android:src="@drawable/icono_actividades"
                            android:layout_width="50dp"
                            android:layout_height="50dp"
                            android:layout_marginEnd="10dp"/>

                        <TextView
                            android:text="SIN NOTIFICACIONES PENDIENTES"
                            android:fontFamily="@font/montserrat_semi_bold"
                            android:textSize="12sp"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"/>
                    </LinearLayout>

                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/rvPendientes"
                        android:layout_width="match_parent"
                        android:layout_height="150dp"
                        android:paddingVertical="15dp"
                        android:visibility="gone"/>

                    <TextView
                        android:text="Análisis de desempeño"
                        android:fontFamily="@font/montserrat_extra_bold_italic"
                        android:textSize="18sp"
                        android:visibility="gone"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"/>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="5dp"
                        android:visibility="gone"
                        android:background="@color/verdeDrawer"/>

                    <androidx.recyclerview.widget.RecyclerView
                        android:paddingVertical="15dp"
                        android:layout_width="match_parent"
                        android:layout_height="200dp"/>

                </LinearLayout>
            </ScrollView>
        </LinearLayout>


        <!-- BOTTOM SHEET -->
        <LinearLayout
            android:id="@+id/bottom_sheet"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:minHeight="50dp"
            android:paddingVertical="25dp"
            android:paddingHorizontal="35dp"
            android:orientation="vertical"
            android:background="@drawable/fondo_bottom_sheet"
            app:layout_behavior="com.google.android.material.bottomsheet.BottomSheetBehavior"
            app:behavior_hideable="false"
            app:behavior_peekHeight="50dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="10dp">
                <TextView
                    android:text="@string/tus_clases"
                    android:textSize="17sp"
                    android:layout_marginBottom="5dp"
                    android:textColor="@color/grisPalidoOscuro"
                    android:fontFamily="@font/montserrat_semi_bold"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"/>

                <Spinner
                    android:id="@+id/opcionesClases"
                    android:padding="5dp"
                    android:background="@drawable/fondo_redondeado"
                    android:backgroundTint="@color/blanco"
                    android:gravity="center"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>
            </LinearLayout>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvClases"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:overScrollMode="never"
                android:scrollbars="vertical"/>

            <TextView
                android:id="@+id/mensajeClases"
                android:text="SIN CLASES REGISTRADAS"
                android:textSize="15sp"
                android:gravity="center"
                android:textAlignment="center"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:fontFamily="@font/montserrat_extra_bold_italic"/>

        </LinearLayout>


        <!-- FLECHA DRAWER -->
        <ImageButton
            android:id="@+id/btnFlechaDrawer"
            android:layout_width="35dp"
            android:layout_height="35dp"
            android:layout_marginTop="150dp"
            android:layout_marginStart="8dp"
            android:src="@drawable/icono_flecha"
            android:background="@null"
            android:elevation="10dp"
            android:scaleType="centerInside"/>

    </androidx.coordinatorlayout.widget.CoordinatorLayout>

    <LinearLayout
        android:id="@+id/drawer_derecho"
        android:layout_width="200dp"
        android:paddingHorizontal="10dp"
        android:layout_height="match_parent"
        android:layout_gravity="start"
        android:background="@drawable/fondo_drawer"
        android:orientation="vertical"
        android:gravity="center_vertical"
        android:paddingTop="50dp"
        android:paddingBottom="100dp">

        <LinearLayout
            android:id="@+id/drawer_seccion_superior"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone"
            android:gravity="center_horizontal"
            android:paddingHorizontal="12dp"
            android:paddingVertical="15dp">

            <FrameLayout
                android:layout_width="100dp"
                android:layout_height="100dp">

                <!-- Imagen circular -->
                <com.google.android.material.imageview.ShapeableImageView
                    android:id="@+id/imgPerfil"
                    android:layout_width="100dp"
                    android:layout_height="100dp"
                    android:scaleType="centerCrop"
                    android:src="@drawable/foto"
                    app:shapeAppearanceOverlay="@style/ImagenCirculo" />

                <!-- Botón editar -->
                <androidx.appcompat.widget.AppCompatImageButton
                    android:id="@+id/editarImagenPerfil"
                    android:layout_width="25dp"
                    android:layout_height="25dp"
                    android:layout_gravity="top|end"
                    android:layout_marginTop="4dp"
                    android:layout_marginEnd="4dp"
                    android:background="@drawable/fondo_editar_foto"
                    android:src="@drawable/icono_editar"
                    android:padding="7dp"
                    app:tint="@color/grisPalidoOscuro"
                    android:scaleType="centerInside"
                    android:elevation="4dp"/>

            </FrameLayout>

        </LinearLayout>

        <TextView
            android:id="@+id/usuario"
            android:text="usuario"
            android:layout_marginTop="5dp"
            android:textSize="15sp"
            android:textAlignment="center"
            android:visibility="gone"
            android:fontFamily="@font/montserrat_extra_bold_italic"
            android:background="@color/verdeClaro"
            android:paddingHorizontal="5dp"
            android:layout_marginHorizontal="25dp"
            android:textColor="@color/verdeOscuro"
            android:paddingVertical="2dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"/>

        <LinearLayout
            android:orientation="horizontal"
            android:layout_width="match_parent"
            android:layout_marginHorizontal="35dp"
            android:layout_height="wrap_content"
            android:layout_marginVertical="15dp"
            android:paddingVertical="7dp"
            android:visibility="gone"
            android:background="@drawable/fondo_creditos"
            android:gravity="center">

            <ImageView
                android:src="@drawable/icono_creditos"
                android:layout_width="20dp"
                android:layout_height="20dp"
                app:tint="@color/amarillo"
                android:layout_marginRight="5dp"
                android:layout_marginHorizontal="3dp"/>

            <TextView
                android:id="@+id/creditos_usuario"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/montserrat_semi_bold"
                android:layout_marginHorizontal="3dp"
                android:text="150"
                android:textColor="@color/amarillo"
                android:textSize="12sp"/>

        </LinearLayout>


            <View
                android:layout_width="match_parent"
                android:layout_height="3dp"
                android:background="@color/verdeClaro"/>

            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/btnCuenta"
                android:text="CUENTA"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/blanco"
                android:visibility="invisible"
                android:background="@drawable/fondo_boton_drawer"
                android:fontFamily="@font/montserrat_extra_bold"
                android:textSize="15sp"/>

            <View
                android:layout_width="match_parent"
                android:layout_height="3dp"
                android:background="@color/verdeClaro"/>

            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/btnPersonalizar"
                android:text="PERSONALIZAR"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/blanco"
                android:visibility="invisible"
                android:background="@drawable/fondo_boton_drawer"
                android:fontFamily="@font/montserrat_extra_bold"
                android:textSize="15sp"/>

            <View
                android:layout_width="match_parent"
                android:layout_height="3dp"
                android:background="@color/verdeClaro"/>

            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/btnGrupos"
                android:text="GRUPOS"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/blanco"
                android:background="@drawable/fondo_boton_drawer"
                android:fontFamily="@font/montserrat_extra_bold"
                android:textSize="15sp"/>

        <View
            android:layout_width="match_parent"
            android:layout_height="3dp"
            android:background="@color/verdeClaro"/>

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btnHorarios"
            android:text="HORARIO"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/blanco"
            android:visibility="invisible"
            android:background="@drawable/fondo_boton_drawer"
            android:fontFamily="@font/montserrat_extra_bold"
            android:textSize="15sp"/>

            <View
                android:layout_width="match_parent"
                android:layout_height="3dp"
                android:background="@color/verdeClaro"/>

            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/btnInformes"
                android:text="INFORMES"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/blanco"
                android:visibility="invisible"
                android:background="@drawable/fondo_boton_drawer"
                android:fontFamily="@font/montserrat_extra_bold"
                android:textSize="15sp"/>

            <View
                android:layout_width="match_parent"
                android:layout_height="3dp"
                android:background="@color/verdeClaro"/>

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btnCreditos"
            android:text="CRÉDITOS"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/blanco"
            android:visibility="invisible"
            android:background="@drawable/fondo_boton_drawer"
            android:fontFamily="@font/montserrat_extra_bold"
            android:textSize="15sp"/>

        <View
            android:layout_width="match_parent"
            android:layout_height="3dp"
            android:background="@color/verdeClaro"/>

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btnNotificaciones"
            android:text="NOTIFICACIONES"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/blanco"
            android:visibility="invisible"
            android:background="@drawable/fondo_boton_drawer"
            android:fontFamily="@font/montserrat_extra_bold"
            android:textSize="15sp"/>

        <View
            android:layout_width="match_parent"
            android:layout_height="3dp"
            android:background="@color/verdeClaro"/>

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btnAcercaDe"
            android:text="ACERCA DE"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/blanco"
            android:visibility="invisible"
            android:background="@drawable/fondo_boton_drawer"
            android:fontFamily="@font/montserrat_extra_bold"
            android:textSize="15sp"/>

        <View
            android:layout_width="match_parent"
            android:layout_height="3dp"
            android:background="@color/verdeClaro"/>

    </LinearLayout>


</androidx.drawerlayout.widget.DrawerLayout>
